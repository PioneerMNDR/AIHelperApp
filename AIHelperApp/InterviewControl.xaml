<UserControl x:Class="AIHelperApp.Controls.InterviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:AIHelperApp.Models"
             Background="Transparent"
             PreviewKeyDown="OnPreviewKeyDown"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <!-- ═══ ЕДИНСТВЕННЫЙ КОРНЕВОЙ ЭЛЕМЕНТ ═══ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: НАСТРОЙКИ СЕССИИ ═══ -->
        <ui:Card x:Name="SettingsPanel" Grid.Row="0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Роль -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Роль" FontSize="11" 
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                               Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="RoleTextBox" 
                                PlaceholderText="Например: Backend Developer"
                                Text="Backend Developer"/>
                </StackPanel>

                <!-- Технический стек -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="Технический стек" FontSize="11" 
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                               Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="TechStackTextBox"
                                PlaceholderText="C#, .NET, Docker..."
                                Text="C#, .NET, Docker"/>
                </StackPanel>

                <!-- Язык транскрипции -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Язык транскрипции" FontSize="11" 
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="LanguageComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="Русский" Tag="ru"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Auto" Tag="auto"/>
                    </ComboBox>
                </StackPanel>

                <!-- Микрофон -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="🎤 Микрофон (ваш голос)" FontSize="11" 
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                               Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="MicComboBox"/>
                        <ui:Button Grid.Column="1" 
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Appearance="Secondary"
                                   Margin="4,0,0,0"
                                   Click="RefreshDevices_Click" 
                                   ToolTipService.ToolTip="Обновить устройства"/>
                    </Grid>
                </StackPanel>

                <!-- Системный звук -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,8,0">
                    <TextBlock Text="🔊 Системный звук (голос интервьюера)" FontSize="11" 
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="LoopbackComboBox"/>
                </StackPanel>

                <!-- Свернуть настройки -->
                <ui:Button Grid.Row="0" Grid.Column="2"
                           Icon="{ui:SymbolIcon ChevronUp24}"
                           Appearance="Transparent"
                           Click="CollapseSettings_Click"
                           ToolTipService.ToolTip="Свернуть настройки"
                           VerticalAlignment="Top"/>
            </Grid>
        </ui:Card>

        <!-- ═══ ROW 1: ОСНОВНОЙ КОНТЕНТ ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: Транскрипция -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                        Padding="12,8" 
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,0,1">
                    <TextBlock>
                        <Run Text="📜 Транскрипция" FontWeight="SemiBold" FontSize="13"/>
                        <Run x:Name="SegmentCountRun" Text="" FontSize="11" 
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>
                </Border>

                <ScrollViewer x:Name="TranscriptionScrollViewer" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="TranscriptionItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="4,2" Padding="8,6">
                                    <ui:Card.Style>
                                        <Style TargetType="ui:Card">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Speaker}" Value="Interviewer">
                                                    <Setter Property="Background" Value="#25cba6f7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Speaker}" Value="User">
                                                    <Setter Property="Background" Value="#2589b4fa"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsScreenshot}" Value="True">
                                                    <Setter Property="Background" Value="#20a6adc8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Card.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Таймкод и иконка -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding TimeCode}" FontSize="10"
                                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                       FontFamily="Consolas"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SpeakerIcon}" FontSize="16"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Контент: текст или скриншот -->
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">

                                            <!-- Лейбл спикера -->
                                            <TextBlock FontSize="10" Margin="0,0,0,2" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" 
                                                                Value="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Speaker}" Value="Interviewer">
                                                                <Setter Property="Foreground" Value="#cba6f7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Speaker}" Value="User">
                                                                <Setter Property="Foreground" Value="#89b4fa"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsScreenshot}" Value="True">
                                                                <Setter Property="Foreground" Value="#a6adc8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding SpeakerLabel, Mode=OneWay}"/>
                                            </TextBlock>

                                            <!-- Текст речи (если это речь) -->
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                       FontSize="13" LineHeight="19"
                                                       Visibility="{Binding IsSpeech, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- Скриншот (если это скриншот) -->
                                            <StackPanel Visibility="{Binding IsScreenshot, Converter={StaticResource BoolToVisibility}}">

                                                <!-- Миниатюра -->
                                                <Border CornerRadius="6" 
                                                        Margin="0,4,0,4"
                                                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        HorizontalAlignment="Left"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="ScreenshotThumbnail_Click"
                                                        Tag="{Binding ScreenshotPath}"
                                                        ToolTipService.ToolTip="Нажмите для просмотра в полном размере">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding ScreenshotThumbnail}" 
                                                                    Stretch="Uniform"/>
                                                    </Border.Background>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Width" Value="200"/>
                                                            <Setter Property="Height" Value="120"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#89b4fa"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>

                                                <!-- Описание скриншота (если есть) -->
                                                <TextBlock Text="{Binding Text}" 
                                                           TextWrapping="Wrap"
                                                           FontSize="11" 
                                                           FontStyle="Italic"
                                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                                           Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibility}}"
                                                           Margin="0,0,0,4"/>

                                                <!-- Информация о скриншоте -->
                                                <TextBlock FontSize="10" 
                                                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}">
                                                    <Run Text="📷"/>
                                                    <Run Text="{Binding ScreenshotFileName, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Индикатор транскрибирования -->
                <Border x:Name="TranscribingIndicator" Grid.Row="1"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="12,0,0,8" Padding="10,5" CornerRadius="10"
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                        Visibility="Collapsed">
                    <TextBlock Text="⏳ Транскрибирую..." FontSize="11"
                               Foreground="#f9e2af" FontStyle="Italic"/>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="3" 
                          Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                          HorizontalAlignment="Stretch" Cursor="SizeWE"/>

            <!-- Правая панель: Ответы AI -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
            Padding="12,8" 
            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" 
            BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock>
                <Run Text="🧠 Ответы AI" FontWeight="SemiBold" FontSize="13"/>
                <Run x:Name="ResponseCountRun" Text="" FontSize="11" 
                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </TextBlock>

                        <!-- Индикатор генерации -->
                        <StackPanel x:Name="GeneratingIndicator" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Visibility="Collapsed">
                            <TextBlock Text="●●●" FontSize="12" Foreground="#f9e2af" 
                           FontWeight="Bold" Margin="0,0,6,0">
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.3" Duration="0:0:0.5"
                                                     AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                            <TextBlock Text="генерирую..." FontSize="11" 
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Список ответов -->
                <ScrollViewer x:Name="ResponsesScrollViewer" Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ResponsesItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="6" Padding="12">
                                    <ui:Card.Style>
                                        <Style TargetType="ui:Card">
                                            <Setter Property="Background" 
                                        Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                                            <Style.Triggers>
                                                <!-- Последний ответ выделен -->
                                                <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                    <Setter Property="Background" Value="#15a6e3a1"/>
                                                    <Setter Property="BorderBrush" Value="#a6e3a1"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Card.Style>

                                    <StackPanel>
                                        <!-- Время -->
                                        <TextBlock Text="{Binding TimestampFormatted}" 
                                       FontSize="10"
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,8"/>

                                        <!-- Вопрос -->
                                        <Border Background="#20f9e2af" 
                                    CornerRadius="6" 
                                    Padding="10,8" 
                                    Margin="0,0,0,10"
                                    Visibility="{Binding HasQuestion, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <TextBlock Text="❓ Вопрос" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"
                                               Foreground="#f9e2af"
                                               Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding DetectedQuestion}" 
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               LineHeight="19"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Ответ -->
                                        <Border Background="#10a6e3a1" 
                                    CornerRadius="6" 
                                    Padding="10,8" 
                                    Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="✅ Ответ" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"
                                               Foreground="#a6e3a1"
                                               Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding AnswerBody}" 
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="21"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Ключевые слова -->
                                        <Border Background="#1589b4fa" 
                                    CornerRadius="6" 
                                    Padding="8,6"
                                    Visibility="{Binding HasKeyWords, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💡" FontSize="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding KeyWords}" 
                                               FontSize="12"
                                               Foreground="#89b4fa"
                                               TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Информация о скриншотах -->
                                        <TextBlock FontSize="10" 
                                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,8,0,0"
                                       Visibility="{Binding HasScreenshots, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="📷 Включено скриншотов:"/>
                                <Run Text="{Binding IncludedScreenshotsCount, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Плейсхолдер когда нет ответов -->
                <StackPanel x:Name="NoResponsesPlaceholder" 
                Grid.Row="1" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Opacity="0.5">
                    <TextBlock Text="🧠" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ответы появятся здесь" FontSize="13" 
                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="Нажмите F2 или кнопку «Ответить»" FontSize="11" 
                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ═══ ROW 2: ПАНЕЛЬ УПРАВЛЕНИЯ ═══ -->
        <ui:Card Grid.Row="2" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Кнопки управления -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button x:Name="RecButton"
                               Appearance="Success"
                               Icon="{ui:SymbolIcon Record24}"
                               Content="REC"
                               Click="RecButton_Click" 
                               ToolTipService.ToolTip="Начать запись (F3)"
                               Margin="0,0,6,0"/>

                    <ui:Button x:Name="PauseButton"
                               Appearance="Caution"
                               Icon="{ui:SymbolIcon Pause24}"
                               Content="Пауза"
                               Click="PauseButton_Click" 
                               IsEnabled="False" 
                               ToolTipService.ToolTip="Пауза (F4)"
                               Margin="0,0,6,0"/>

                    <ui:Button x:Name="StopButton"
                               Appearance="Danger"
                               Icon="{ui:SymbolIcon Stop24}"
                               Content="Стоп"
                               Click="StopButton_Click" 
                               IsEnabled="False" 
                               ToolTipService.ToolTip="Остановить"
                               Margin="0,0,6,0"/>

                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,4"/>

                    <ui:Button x:Name="ScreenshotButton"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Camera24}"
                               Content="F5"
                               Click="ScreenshotButton_Click"
                               IsEnabled="False" 
                               ToolTipService.ToolTip="Снимок экрана (F5)"
                               Margin="0,0,6,0"/>

                    <ui:Button x:Name="AnswerButton"
           Appearance="Primary"
           Icon="{ui:SymbolIcon Brain24}"
           Content="Ответить F2"
           Click="AnswerButton_Click"
           IsEnabled="False" 
           ToolTipService.ToolTip="Отправить в AI (F2)"
           Margin="0,0,6,0"/>

                    <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="8,4"/>

                    <ui:Button Icon="{ui:SymbolIcon Settings24}"
                               Appearance="Transparent"
                               Click="ExpandSettings_Click" 
                               ToolTipService.ToolTip="Настройки сессии"/>
                </StackPanel>

                <!-- VU-метры -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🎤 Интервьюер:" FontSize="11"
                               Foreground="#cba6f7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Grid.Column="1" Background="#30cba6f7" CornerRadius="3"
                            Height="6" x:Name="InterviewerVuContainer">
                        <Rectangle x:Name="InterviewerVuBar" Fill="#cba6f7"
                                   HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                   Width="0"/>
                    </Border>

                    <TextBlock Grid.Column="3" Text="🙋 Вы:" FontSize="11"
                               Foreground="#89b4fa" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Grid.Column="4" Background="#3089b4fa" CornerRadius="3"
                            Height="6" x:Name="UserVuContainer">
                        <Rectangle x:Name="UserVuBar" Fill="#89b4fa"
                                   HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                   Width="0"/>
                    </Border>
                </Grid>

                <!-- Авто-триггер -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="AutoTriggerCheckBox" IsChecked="True"
                              VerticalContentAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Авто-ответ при тишине"/>
                    </CheckBox>

                    <TextBlock Text="Порог:" FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="SilenceThresholdComboBox" MinWidth="80" SelectedIndex="1">
                        <ComboBoxItem Content="1 сек" Tag="1"/>
                        <ComboBoxItem Content="2 сек" Tag="2"/>
                        <ComboBoxItem Content="3 сек" Tag="3"/>
                        <ComboBoxItem Content="5 сек" Tag="5"/>
                    </ComboBox>
                </StackPanel>

                <!-- Статус-бар -->
                <ui:Card Grid.Row="3" Padding="10,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" 
                 Fill="{ui:ThemeResource TextFillColorTertiaryBrush}"
                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="RecordingStatusText" Text="Готов к записи"
                   FontSize="12" 
                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,2,12,2"/>

                        <TextBlock FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0">
            <Run Text="⏱"/>
            <Run x:Name="ElapsedRun" Text="00:00"/>
                        </TextBlock>

                        <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,2,12,2"/>

                        <TextBlock FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0">
            <Run Text="Whisper:" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
            <Run x:Name="WhisperStatusRun" Text="не загружен" Foreground="#f9e2af"/>
                        </TextBlock>

                        <Border Width="1" Background="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,2,12,2"/>

                        <!-- Обновлённый Qwen статус -->
                        <TextBlock FontSize="11" VerticalAlignment="Center">
            <Run Text="Qwen:" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
            <Run x:Name="QwenStatusRun" Text=" —" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </ui:Card>

        <!-- ═══ OVERLAY: Скачивание модели ═══ -->
        <Border x:Name="ModelDownloadOverlay" Grid.Row="0" Grid.RowSpan="3"
                Background="{ui:ThemeResource ApplicationBackgroundBrush}" 
                Opacity="0.90"
                Visibility="Collapsed" CornerRadius="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
                <TextBlock Text="🤖" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Whisper модель не найдена" FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="13" 
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                           Margin="0,0,0,16">
                    Для транскрипции речи необходима модель Whisper (~548 МБ).
                    Она будет скачана один раз и сохранена локально.
                </TextBlock>

                <ui:Button x:Name="DownloadModelButton"
                           Content="Скачать модель"
                           Icon="{ui:SymbolIcon ArrowDownload24}"
                           Appearance="Primary"
                           FontWeight="SemiBold"
                           Click="DownloadModel_Click"
                           HorizontalAlignment="Center"/>

                <StackPanel x:Name="DownloadProgressPanel" Visibility="Collapsed" Margin="0,16,0,0">
                    <ProgressBar x:Name="ModelDownloadProgress" 
                                 Height="6" 
                                 Minimum="0" 
                                 Maximum="100"
                                 Margin="0,0,0,8"/>
                    <TextBlock x:Name="DownloadStatusText" 
                               Text="Скачивание..."
                               FontSize="12" 
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ OVERLAY: Просмотр скриншота ═══ -->
        <Border x:Name="ScreenshotViewerOverlay" 
                Grid.Row="0" Grid.RowSpan="3"
                Background="#E0181825"
                Visibility="Collapsed" 
                MouseLeftButtonUp="CloseScreenshotViewer_Click"
                Cursor="Hand">

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0" 
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="8,8,0,0" 
                        Padding="16,12">
                    <Grid>
                        <TextBlock x:Name="ScreenshotViewerTitle"
                                   Text="📷 Скриншот"
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <ui:Button HorizontalAlignment="Right"
                                   Icon="{ui:SymbolIcon Dismiss24}"
                                   Appearance="Transparent"
                                   Click="CloseScreenshotViewer_Click"
                                   ToolTipService.ToolTip="Закрыть (Esc или клик)"/>
                    </Grid>
                </Border>

                <!-- Изображение -->
                <Border Grid.Row="1" 
                        Background="#20000000"
                        CornerRadius="0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PanningMode="Both">
                        <Image x:Name="ScreenshotViewerImage"
                               Stretch="Uniform"
                               MaxWidth="1600"
                               MaxHeight="900"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               MouseLeftButtonUp="ScreenshotViewerImage_Click"/>
                    </ScrollViewer>
                </Border>

                <!-- Нижняя панель с информацией -->
                <Border Grid.Row="2" 
                        Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="0,0,8,8" 
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ScreenshotViewerInfo"
                                   Text="Разрешение: 1920x1080"
                                   FontSize="11"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button Content="Открыть папку"
                                       Icon="{ui:SymbolIcon Folder24}"
                                       Appearance="Secondary"
                                       Click="OpenScreenshotFolder_Click"
                                       Margin="0,0,8,0"/>

                            <ui:Button x:Name="CopyPathButton"
                                       Content="Копировать путь"
                                       Icon="{ui:SymbolIcon Copy24}"
                                       Appearance="Secondary"
                                       Click="CopyScreenshotPath_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>