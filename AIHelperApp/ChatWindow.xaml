<blur:BlurWindow x:Class="AIHelperApp.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIHelperApp"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:blur="clr-namespace:TianXiaTech;assembly=BlurWindow"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        xmlns:controls="clr-namespace:AIHelperApp.Controls"
        Title="AI Chat Assistant"
        Width="950" Height="750"
        MinWidth="650" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        TitleVisibility="Hidden"
        IconVisibility="Collapsed"
        ControlBoxVisibility="Hidden"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <blur:BlurWindow.Background>
        <SolidColorBrush Color="#1e1e2e" Opacity=".6"/>
    </blur:BlurWindow.Background>

    <Window.Resources>
        <local:BoolToAlignmentConverter x:Key="AlignmentConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <local:FileSizeConverter x:Key="FileSizeConverter"/>

        <!-- ═══ Catppuccin Mocha ═══ -->
        <SolidColorBrush x:Key="TextBrush" Color="#cdd6f4"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="#a6adc8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#313244"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="#45475a"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#89b4fa"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#a6e3a1"/>
        <SolidColorBrush x:Key="RedBrush" Color="#f38ba8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#f9e2af"/>
        <SolidColorBrush x:Key="MauveBrush" Color="#cba6f7"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#fab387"/>

        <!-- ═══ Стиль MarkdownScrollViewer для AI-сообщений ═══ -->
        <Style x:Key="AiMarkdownViewer" TargetType="mdxaml:MarkdownScrollViewer">
            <Setter Property="MarkdownStyleName" Value="Sasabune"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- ═══ Анимации тоггла ═══ -->
        <Storyboard x:Key="ToggleOn">
            <DoubleAnimation Storyboard.TargetName="ToggleCircle"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             To="22" Duration="0:0:0.15"/>
            <ColorAnimation Storyboard.TargetName="ToggleBg"
                            Storyboard.TargetProperty="Fill.Color"
                            To="#a6e3a1" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="ToggleOff">
            <DoubleAnimation Storyboard.TargetName="ToggleCircle"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             To="4" Duration="0:0:0.15"/>
            <ColorAnimation Storyboard.TargetName="ToggleBg"
                            Storyboard.TargetProperty="Fill.Color"
                            To="#585b70" Duration="0:0:0.15"/>
        </Storyboard>

        <!-- ═══ Кнопка акцентная ═══ -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueBrush}"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#74c7ec"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface1Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource AccentBtn}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- ═══ Кнопка-иконка ═══ -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface1Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Кнопка удаления файла ═══ -->
        <Style x:Key="FileRemoveBtn" TargetType="Button">
            <Setter Property="Background" Value="#40f38ba8"/>
            <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Поле ввода ═══ -->
        <Style x:Key="ChatTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TabControl в стиле Catppuccin Mocha ═══ -->
        <Style x:Key="CatppuccinTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ═══ Стиль заголовка вкладки ═══ -->
        <Style x:Key="CatppuccinTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8,8,0,0"
                                Margin="0,0,4,0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource Surface1Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: TITLEBAR -->
        <ui:TitleBar Grid.Row="0" Title="🤖 AI Chat Assistant" Height="30" Margin="0,-28,0,0"/>

        <!-- ROW 1: ТУЛБАР -->
        <Border Grid.Row="1" Background="#C0252535" Padding="16,8" CornerRadius="10"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}" 
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="Подключение..." 
                               FontSize="12" Foreground="{StaticResource SubtextBrush}" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="Модель:" Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                    <ComboBox x:Name="ModelComboBox" Width="150" Padding="8,5"
                              SelectionChanged="ModelComboBox_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="⚙️" Style="{StaticResource IconBtn}" 
                            ToolTip="System Prompt" Click="SystemPrompt_Click"/>
                    <Button Content="🔄" Style="{StaticResource IconBtn}" 
                            ToolTip="Новый чат" Click="NewChat_Click" Margin="4,0"/>
                </StackPanel>

                <Border Grid.Column="4" Width="1" Background="{StaticResource Surface1Brush}" Margin="8,2"/>

                <Border Grid.Column="5" Background="#20ffffff" CornerRadius="8" 
                        Padding="8,4" VerticalAlignment="Center"
                        ToolTip="Скрыть от захвата экрана (Ctrl+`)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="StealthIcon" Text="🔒" FontSize="12" 
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="StealthStatusText" Text="Скрыто" FontSize="11" 
                                   FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Canvas Width="42" Height="22" Cursor="Hand" Background="Transparent"
                                MouseLeftButtonDown="StealthToggle_Click" VerticalAlignment="Center">
                            <Rectangle x:Name="ToggleBg" Width="42" Height="22" RadiusX="11" RadiusY="11">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="#a6e3a1"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Ellipse x:Name="ToggleCircle" Width="16" Height="16" 
                                     Fill="White" Canvas.Top="3" Canvas.Left="22">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ROW 2: SYSTEM PROMPT -->
        <Border x:Name="SystemPromptPanel" Grid.Row="2" Background="#D0252535"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,0,0,1"
                Padding="16,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Margin="0,0,0,6">
                        <Run Text="⚙️ System Prompt" FontWeight="SemiBold" 
                             Foreground="{StaticResource YellowBrush}"/>
                        <Run Text=" — инструкции для AI" FontSize="12"
                             Foreground="{StaticResource SubtextBrush}"/>
                    </TextBlock>
                    <TextBox x:Name="SystemPromptTextBox" Style="{StaticResource ChatTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="70"
                             VerticalScrollBarVisibility="Auto"
                             Text="Ты — полезный AI-ассистент. Отвечай кратко и по существу на русском языке."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,20,0,0" VerticalAlignment="Center">
                    <Button Content="✓ Применить" Style="{StaticResource SmallBtn}" 
                            Background="{StaticResource GreenBrush}"
                            Click="ApplySystemPrompt_Click" Margin="0,0,0,6"/>
                    <Button Content="✕ Очистить" Style="{StaticResource SmallBtn}" 
                            Background="{StaticResource Surface1Brush}"
                            Click="ClearSystemPrompt_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 3: TABS -->
        <controls:TabControlEx x:Name="MainTabControl" 
                           Background="Transparent" 
                           BorderThickness="0"  Grid.Row="3"
                           Padding="16,0" >

            <!-- ═══ Вкладка 1: Chat ═══ -->
            <TabItem Header="💬 Chat" Style="{StaticResource CatppuccinTabItem}">
                <Grid Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Сообщения чата -->
                    <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,8">
                        <ItemsControl x:Name="MessagesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,4" Padding="12,10" CornerRadius="12" MaxWidth="700"
                                            HorizontalAlignment="{Binding IsUser, Converter={StaticResource AlignmentConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#CC313244"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="#DD89b4fa"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                        <Setter Property="Background" Value="#AA45475a"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <!-- Заголовок -->
                                            <TextBlock FontSize="10" Opacity="0.7" Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#a6adc8"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding Role}" FontWeight="SemiBold"/>
                                                <Run Text=" • "/>
                                                <Run Text="{Binding Timestamp}"/>
                                            </TextBlock>

                                            <!-- Прикреплённые файлы -->
                                            <ItemsControl ItemsSource="{Binding Attachments}" 
                                                          Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}"
                                                          Margin="0,0,0,6">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Margin="0,0,6,4" Padding="6,4"
                                                                MaxWidth="200">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#30000000"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                            <Setter Property="Background" Value="#30f38ba8"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel>
                                                                <Image Source="{Binding LocalPath}" MaxHeight="120" MaxWidth="180"
                                                                       Stretch="Uniform" Margin="0,0,0,4"
                                                                       Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text="🎵" FontSize="24" HorizontalAlignment="Center" 
                                                                           Margin="0,0,0,4"
                                                                           Visibility="{Binding IsAudio, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Text="📄">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsAudio}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock FontSize="11" TextTrimming="CharacterEllipsis">
                                                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                                                    <Run Text=" "/>
                                                                    <Run Text="{Binding SizeFormatted, Mode=OneWay}" Foreground="#80ffffff" FontSize="9"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- ═══ MARKDOWN для AI/System сообщений ═══ -->
                                            <mdxaml:MarkdownScrollViewer 
                                                Markdown="{Binding Content}"
                                                Style="{StaticResource AiMarkdownViewer}"
                                                Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibility}}"/>

                                            <!-- ═══ Обычный текст для пользователя ═══ -->
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" 
                                                       FontSize="14" LineHeight="20"
                                                       Foreground="#1e1e2e"
                                                       Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Индикатор загрузки -->
                    <Border x:Name="LoadingIndicator" Grid.Row="0" Visibility="Collapsed"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="24,0,0,16" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="12" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LoadingDots" Text="●●●" 
                                       Foreground="{StaticResource BlueBrush}" FontSize="14"/>
                            <TextBlock Text=" AI думает..." Foreground="{StaticResource SubtextBrush}" 
                                       FontSize="12" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Превью прикреплённых файлов -->
                    <Border x:Name="AttachmentsPanel" Grid.Row="1" 
                            Background="#B0252535"
                            BorderBrush="{StaticResource Surface1Brush}" 
                            BorderThickness="0,1,0,0"
                            Padding="16,8" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <Run Text="📎" FontSize="14"/>
                                    <Run x:Name="AttachmentCountText" Text=" 0 файлов" 
                                         FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                                </TextBlock>
                                <Button DockPanel.Dock="Right" Content="✕ Убрать все" 
                                        Style="{StaticResource SmallBtn}"
                                        Background="{StaticResource Surface1Brush}"
                                        Click="ClearAttachments_Click"
                                        HorizontalAlignment="Right"/>
                                <StackPanel x:Name="UploadProgressPanel" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock x:Name="UploadProgressText" Text="Загрузка..." 
                                               FontSize="11" Foreground="{StaticResource YellowBrush}" 
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ProgressBar x:Name="UploadProgressBar" Width="120" Height="4" 
                                                 Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource BlueBrush}"
                                                 Background="{StaticResource Surface1Brush}"/>
                                </StackPanel>
                            </DockPanel>

                            <ItemsControl x:Name="AttachmentsItemsControl" Grid.Row="1">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#40313244" CornerRadius="8" Padding="8,6" 
                                                Margin="0,0,8,4" MaxWidth="200">
                                            <Grid>
                                                <Button Style="{StaticResource FileRemoveBtn}" 
                                                        Content="✕" 
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Margin="0,-2,-4,0"
                                                        Click="RemoveAttachment_Click"
                                                        Tag="{Binding}"/>
                                                <StackPanel Margin="0,0,20,0">
                                                    <Image Source="{Binding LocalPath}" MaxHeight="80" MaxWidth="160"
                                                           Stretch="Uniform" Margin="0,0,0,4"
                                                           Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="🎵" FontSize="28" HorizontalAlignment="Center" 
                                                               Margin="0,4,0,4"
                                                               Foreground="{StaticResource PeachBrush}"
                                                               Visibility="{Binding IsAudio, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Text="📄">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsAudio}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding SizeFormatted, Mode=OneWay}" Foreground="#80ffffff" FontSize="9"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding SizeFormatted}" FontSize="9" 
                                                               Foreground="{StaticResource SubtextBrush}"/>
                                                    <ProgressBar Height="2" Margin="0,3,0,0"
                                                                 Foreground="{StaticResource BlueBrush}"
                                                                 Background="{StaticResource Surface1Brush}"
                                                                 Value="{Binding UploadProgress}" Maximum="1"
                                                                 Visibility="{Binding IsUploading, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="{Binding ErrorMessage}" FontSize="9" 
                                                               Foreground="{StaticResource RedBrush}" TextWrapping="Wrap"
                                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- ═══ Ввод сообщения ═══ -->
                    <Border Grid.Row="2" Background="#D0313244"
                            BorderBrush="{StaticResource Surface1Brush}" 
                            BorderThickness="0,1,0,0" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Кнопка прикрепления -->
                            <Button x:Name="AttachButton" Grid.Column="0"
                                    Style="{StaticResource IconBtn}" 
                                    Content="📎" FontSize="18"
                                    ToolTip="Прикрепить файл (Ctrl+F)"
                                    Click="AttachFile_Click" 
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Bottom"/>

                            <!-- Многострочное поле ввода -->
                            <TextBox x:Name="InputTextBox" Grid.Column="1"
                                     Style="{StaticResource ChatTextBox}"
                                     AcceptsReturn="True" 
                                     MinHeight="40" MaxHeight="150" 
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" 
                                     PreviewKeyDown="InputTextBox_PreviewKeyDown"/>

                            <!-- Правая панель -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                <Button x:Name="SendButton"
                                        Content="Отправить ➤"
                                        Style="{StaticResource AccentBtn}" 
                                        Click="SendButton_Click"/>
                                <TextBlock Text="Ctrl+Enter" 
                                           FontSize="9" Foreground="{StaticResource SubtextBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ Вкладка 2: Interview ═══ -->
            <TabItem Header="🎙️ Interview" Style="{StaticResource CatppuccinTabItem}">
                <controls:InterviewControl x:Name="InterviewCtrl"/>
            </TabItem>
        </controls:TabControlEx>
        <!-- Overlay для Drag & Drop -->
        <Border x:Name="DragDropOverlay" Grid.Row="3" 
                Background="#C01e1e2e" Visibility="Collapsed"
                IsHitTestVisible="False">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📎" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Перетащите файлы сюда" FontSize="18" 
                           Foreground="{StaticResource BlueBrush}" 
                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                <TextBlock Text="Изображения, аудио, PDF, документы (до 20 МБ)" 
                           FontSize="12" Foreground="{StaticResource SubtextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</blur:BlurWindow>