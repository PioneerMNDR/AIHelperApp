<blur:BlurWindow x:Class="AIHelperApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIHelperApp"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:blur="clr-namespace:TianXiaTech;assembly=BlurWindow"
        xmlns:controls="clr-namespace:AIHelperApp.Controls"
        Title="AI Helper"
        Width="950" Height="750"
        MinWidth="650" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        TitleVisibility="Hidden"   AcrylicOpacity="128"
        IconVisibility="Collapsed" 
        ControlBoxVisibility="Hidden">

    <blur:BlurWindow.Background>
        <SolidColorBrush Color="#1e1e2e" Opacity=".6"/>
    </blur:BlurWindow.Background>

    <Window.Resources>
        <!-- ═══ Catppuccin Mocha ═══ -->
        <SolidColorBrush x:Key="TextBrush" Color="#cdd6f4"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="#a6adc8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#313244"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="#45475a"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#89b4fa"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#a6e3a1"/>
        <SolidColorBrush x:Key="RedBrush" Color="#f38ba8"/>

        <!-- ═══ Анимации тоггла ═══ -->
        <Storyboard x:Key="ToggleOn">
            <DoubleAnimation Storyboard.TargetName="ToggleCircle"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             To="16" Duration="0:0:0.15"/>
            <ColorAnimation Storyboard.TargetName="ToggleBg"
                            Storyboard.TargetProperty="Fill.Color"
                            To="#a6e3a1" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="ToggleOff">
            <DoubleAnimation Storyboard.TargetName="ToggleCircle"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             To="3" Duration="0:0:0.15"/>
            <ColorAnimation Storyboard.TargetName="ToggleBg"
                            Storyboard.TargetProperty="Fill.Color"
                            To="#585b70" Duration="0:0:0.15"/>
        </Storyboard>

        <!-- ═══ Стиль заголовка вкладки ═══ -->
        <Style x:Key="CatppuccinTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10,10,0,0"
                                Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#40313244"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#20313244"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: TITLEBAR -->
        <ui:TitleBar Grid.Row="0" Title="🤖 AI Helper" Height="30" Margin="0,-28,0,0"/>

        <!-- ROW 1: TABS -->
        <controls:TabControlEx x:Name="MainTabControl" Grid.Row="1"
                               Background="Transparent" 
                               BorderThickness="0"
                               Padding="12,0">

            <!-- ═══ Вкладка 1: Chat ═══ -->
            <TabItem Header="💬 Chat" Style="{StaticResource CatppuccinTabItem}">
                <controls:ChatControl x:Name="ChatCtrl"/>
            </TabItem>

            <!-- ═══ Вкладка 2: Interview ═══ -->
            <TabItem Header="🎙️ Interview" Style="{StaticResource CatppuccinTabItem}">
                <controls:InterviewControl x:Name="InterviewCtrl"/>
            </TabItem>
        </controls:TabControlEx>

        <!-- ROW 2: FOOTER -->
        <Border Grid.Row="2" Background="#60252535" Padding="12,6"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть: подсказка -->
                <TextBlock Grid.Column="0" 
                           Text="Ctrl+` — переключить видимость" 
                           FontSize="10" 
                           Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center"
                           Opacity="0.6"/>

                <!-- Правая часть: переключатель стелс-режима -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StealthIcon" Text="🔒" FontSize="11" 
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StealthStatusText" Text="Скрыто" FontSize="10" 
                               FontWeight="Medium" Foreground="{StaticResource GreenBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <!-- Маленький тоггл -->
                    <Canvas Width="30" Height="16" Cursor="Hand" Background="Transparent"
                            MouseLeftButtonDown="StealthToggle_Click" VerticalAlignment="Center"
                            ToolTip="Скрыть от захвата экрана (Ctrl+`)">
                        <Rectangle x:Name="ToggleBg" Width="30" Height="16" RadiusX="8" RadiusY="8">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="#a6e3a1"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Ellipse x:Name="ToggleCircle" Width="12" Height="12" 
                                 Fill="White" Canvas.Top="2" Canvas.Left="16">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.25"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</blur:BlurWindow>