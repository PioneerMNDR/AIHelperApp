<blur:BlurWindow x:Class="AIHelperApp.MainWindowWin10"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:blur="clr-namespace:TianXiaTech;assembly=BlurWindow"
        xmlns:controls="clr-namespace:AIHelperApp.Controls"
        Title="AI Helper"
        Width="950" Height="750"
        MinWidth="650" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        TitleVisibility="Hidden"
        AcrylicOpacity="128"
        IconVisibility="Collapsed"
        ControlBoxVisibility="Hidden">

    <blur:BlurWindow.Background>
        <SolidColorBrush Color="#1e1e2e" Opacity=".6"/>
    </blur:BlurWindow.Background>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="🤖 AI Helper"
                     Height="30" Margin="0,-28,0,0"/>

        <controls:MainContent Grid.Row="1" x:Name="ContentArea"/>
    </Grid>
</blur:BlurWindow>