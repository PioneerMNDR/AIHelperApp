<UserControl x:Class="AIHelperApp.Controls.ChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AIHelperApp.Data"
             xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
             AllowDrop="True"
             Drop="Control_Drop"
             DragOver="Control_DragOver"
             DragLeave="Control_DragLeave">

    <UserControl.Resources>
        <local:BoolToAlignmentConverter x:Key="AlignmentConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <local:FileSizeConverter x:Key="FileSizeConverter"/>

        <!-- ═══ Catppuccin Mocha ═══ -->
        <SolidColorBrush x:Key="TextBrush" Color="#cdd6f4"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="#a6adc8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#313244"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="#45475a"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#89b4fa"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#a6e3a1"/>
        <SolidColorBrush x:Key="RedBrush" Color="#f38ba8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#f9e2af"/>
        <SolidColorBrush x:Key="MauveBrush" Color="#cba6f7"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#fab387"/>

        <!-- ═══ Стиль MarkdownScrollViewer для AI-сообщений ═══ -->
        <Style x:Key="AiMarkdownViewer" TargetType="mdxaml:MarkdownScrollViewer">
            <Setter Property="MarkdownStyleName" Value="Sasabune"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- ═══ Кнопка акцентная ═══ -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueBrush}"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#74c7ec"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface1Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource AccentBtn}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- ═══ Кнопка-иконка ═══ -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface1Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Кнопка удаления файла ═══ -->
        <Style x:Key="FileRemoveBtn" TargetType="Button">
            <Setter Property="Background" Value="#40f38ba8"/>
            <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Поле ввода ═══ -->
        <Style x:Key="ChatTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: ТУЛБАР ЧАТА -->
        <Border Grid.Row="0" Background="#80252535" Padding="12,8" CornerRadius="8" Margin="4,8,4,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статус подключения -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="8" Height="8" Fill="{StaticResource SubtextBrush}" 
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="Подключение..." 
                               FontSize="11" Foreground="{StaticResource SubtextBrush}" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Выбор модели -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="Модель:" Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                    <ComboBox x:Name="ModelComboBox" Width="140" Padding="8,4" FontSize="11"
                              SelectionChanged="ModelComboBox_SelectionChanged"/>
                </StackPanel>

                <!-- Кнопки действий -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="⚙️" Style="{StaticResource IconBtn}" 
                            ToolTip="System Prompt" Click="SystemPrompt_Click" FontSize="13"/>
                    <Button Content="🔄" Style="{StaticResource IconBtn}" 
                            ToolTip="Новый чат" Click="NewChat_Click" Margin="2,0,0,0" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: SYSTEM PROMPT -->
        <Border x:Name="SystemPromptPanel" Grid.Row="1" Background="#D0252535"
                CornerRadius="8" Margin="4,0,4,4" Padding="12,10" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Margin="0,0,0,6">
                        <Run Text="⚙️ System Prompt" FontWeight="SemiBold" FontSize="12"
                             Foreground="{StaticResource YellowBrush}"/>
                        <Run Text=" — инструкции для AI" FontSize="11"
                             Foreground="{StaticResource SubtextBrush}"/>
                    </TextBlock>
                    <TextBox x:Name="SystemPromptTextBox" Style="{StaticResource ChatTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                             VerticalScrollBarVisibility="Auto" FontSize="12"
                             Text="Ты — полезный AI-ассистент. Отвечай кратко и по существу на русском языке."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,16,0,0" VerticalAlignment="Center">
                    <Button Content="✓ Применить" Style="{StaticResource SmallBtn}" 
                            Background="{StaticResource GreenBrush}"
                            Click="ApplySystemPrompt_Click" Margin="0,0,0,4"/>
                    <Button Content="✕ Очистить" Style="{StaticResource SmallBtn}" 
                            Background="{StaticResource Surface1Brush}"
                            Click="ClearSystemPrompt_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 2: СООБЩЕНИЯ ЧАТА -->
        <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="4,0">
            <Grid>
                <ItemsControl x:Name="MessagesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,4" Padding="12,10" CornerRadius="12" MaxWidth="680"
                                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource AlignmentConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#CC313244"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="Background" Value="#DD89b4fa"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                <Setter Property="Background" Value="#AA45475a"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <!-- Заголовок -->
                                    <TextBlock FontSize="10" Opacity="0.7" Margin="0,0,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#a6adc8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Foreground" Value="#1e1e2e"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding Role}" FontWeight="SemiBold"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding Timestamp}"/>
                                    </TextBlock>

                                    <!-- Прикреплённые файлы -->
                                    <ItemsControl ItemsSource="{Binding Attachments}" 
                                                  Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}"
                                                  Margin="0,0,0,6">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Margin="0,0,6,4" Padding="6,4"
                                                        MaxWidth="180" Background="#30000000">
                                                    <StackPanel>
                                                        <Image Source="{Binding LocalPath}" MaxHeight="100" MaxWidth="160"
                                                               Stretch="Uniform" Margin="0,0,0,4"
                                                               Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}"/>
                                                        <TextBlock Text="🎵" FontSize="20" HorizontalAlignment="Center" 
                                                                   Margin="0,0,0,4"
                                                                   Visibility="{Binding IsAudio, Converter={StaticResource BoolToVisibility}}"/>
                                                        <TextBlock FontSize="10" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- MARKDOWN для AI/System сообщений -->
                                    <mdxaml:MarkdownScrollViewer 
                                        Markdown="{Binding Content}"
                                        Style="{StaticResource AiMarkdownViewer}"
                                        Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibility}}"/>

                                    <!-- Обычный текст для пользователя -->
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" 
                                               FontSize="14" LineHeight="20"
                                               Foreground="#1e1e2e"
                                               Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Индикатор загрузки -->
                <Border x:Name="LoadingIndicator" Visibility="Collapsed"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="20,0,0,12" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="LoadingDots" Text="●●●" 
                                   Foreground="{StaticResource BlueBrush}" FontSize="12"/>
                        <TextBlock Text=" AI думает..." Foreground="{StaticResource SubtextBrush}" 
                                   FontSize="11" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- ROW 3: ПРЕВЬЮ ПРИКРЕПЛЁННЫХ ФАЙЛОВ -->
        <Border x:Name="AttachmentsPanel" Grid.Row="3" 
                Background="#B0252535" CornerRadius="8,8,0,0"
                Margin="4,0,4,0" Padding="12,8" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Run Text="📎" FontSize="12"/>
                        <Run x:Name="AttachmentCountText" Text=" 0 файлов" 
                             FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                    </TextBlock>
                    <Button DockPanel.Dock="Right" Content="✕ Убрать" 
                            Style="{StaticResource SmallBtn}"
                            Background="{StaticResource Surface1Brush}"
                            Click="ClearAttachments_Click"
                            HorizontalAlignment="Right"/>
                    <StackPanel x:Name="UploadProgressPanel" Orientation="Horizontal" 
                                HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="UploadProgressText" Text="Загрузка..." 
                                   FontSize="10" Foreground="{StaticResource YellowBrush}" 
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ProgressBar x:Name="UploadProgressBar" Width="100" Height="4" 
                                     Minimum="0" Maximum="100" Value="0"
                                     Foreground="{StaticResource BlueBrush}"
                                     Background="{StaticResource Surface1Brush}"/>
                    </StackPanel>
                </DockPanel>

                <ItemsControl x:Name="AttachmentsItemsControl" Grid.Row="1">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#40313244" CornerRadius="6" Padding="6,4" 
                                    Margin="0,0,6,4" MaxWidth="160">
                                <Grid>
                                    <Button Style="{StaticResource FileRemoveBtn}" 
                                            Content="✕" 
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-2,-2,0"
                                            Click="RemoveAttachment_Click"
                                            Tag="{Binding}"/>
                                    <StackPanel Margin="0,0,18,0">
                                        <Image Source="{Binding LocalPath}" MaxHeight="60" MaxWidth="120"
                                               Stretch="Uniform" Margin="0,0,0,3"
                                               Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="🎵" FontSize="22" HorizontalAlignment="Center" 
                                                   Margin="0,2,0,3"
                                                   Foreground="{StaticResource PeachBrush}"
                                                   Visibility="{Binding IsAudio, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock FontSize="10" TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding SizeFormatted}" FontSize="9" 
                                                   Foreground="{StaticResource SubtextBrush}"/>
                                        <ProgressBar Height="2" Margin="0,2,0,0"
                                                     Foreground="{StaticResource BlueBrush}"
                                                     Background="{StaticResource Surface1Brush}"
                                                     Value="{Binding UploadProgress}" Maximum="1"
                                                     Visibility="{Binding IsUploading, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ROW 4: ВВОД СООБЩЕНИЯ -->
        <Border Grid.Row="4" Background="#D0313244" CornerRadius="0,0,8,8"
                Margin="4,0,4,4" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка прикрепления -->
                <Button x:Name="AttachButton" Grid.Column="0"
                        Style="{StaticResource IconBtn}" 
                        Content="📎" FontSize="16"
                        ToolTip="Прикрепить файл (Ctrl+F)"
                        Click="AttachFile_Click" 
                        Margin="0,0,6,0"
                        VerticalAlignment="Bottom"/>

                <!-- Многострочное поле ввода -->
                <TextBox x:Name="InputTextBox" Grid.Column="1"
                         Style="{StaticResource ChatTextBox}"
                         AcceptsReturn="True" 
                         MinHeight="36" MaxHeight="120" 
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" 
                         PreviewKeyDown="InputTextBox_PreviewKeyDown"/>

                <!-- Правая панель -->
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0,0,0">
                    <Button x:Name="SendButton"
                            Content="➤"
                            Style="{StaticResource AccentBtn}" 
                            Padding="14,8"
                            FontSize="14"
                            Click="SendButton_Click"/>
                    <TextBlock Text="Ctrl+Enter" 
                               FontSize="8" Foreground="{StaticResource SubtextBrush}"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Overlay для Drag & Drop -->
        <Border x:Name="DragDropOverlay" Grid.RowSpan="5" 
                Background="#E01e1e2e" CornerRadius="8"
                Margin="4" Visibility="Collapsed"
                IsHitTestVisible="False">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📎" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="Перетащите файлы сюда" FontSize="16" 
                           Foreground="{StaticResource BlueBrush}" 
                           HorizontalAlignment="Center" Margin="0,10,0,4"/>
                <TextBlock Text="Изображения, аудио, документы (до 20 МБ)" 
                           FontSize="11" Foreground="{StaticResource SubtextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>